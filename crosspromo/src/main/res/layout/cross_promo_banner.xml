<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="@drawable/cross_promo_bg">

    <FrameLayout
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/cross_promo_icon_bg">

        <ImageView
            android:id="@+id/cpIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:padding="2dp" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/cpTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="#212121"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/cpDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#757575"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <Button
        android:id="@+id/cpInstall"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="Install"
        android:textSize="12sp"
        android:textColor="#1976D2"
        android:minWidth="80dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@drawable/cross_promo_button_bg"
        android:textAllCaps="false" />

</LinearLayout>
