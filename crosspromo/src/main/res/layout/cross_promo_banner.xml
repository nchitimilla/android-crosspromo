<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/cross_promo_bg"
    android:elevation="2dp">

    <TextView
        android:id="@+id/cpLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/crosspromo_suggested"
        android:textSize="10sp"
        android:textColor="@color/crosspromo_label_text"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/cross_promo_icon_bg">

            <ImageView
                android:id="@+id/cpIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:padding="3dp" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="10dp">

            <TextView
                android:id="@+id/cpTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="@color/crosspromo_title_text"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/cpDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/crosspromo_description_text"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingMultiplier="1.15"
                android:layout_marginTop="3dp" />

        </LinearLayout>

        <Button
            android:id="@+id/cpInstall"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/crosspromo_install"
            android:textSize="13sp"
            android:textColor="@android:color/white"
            android:fontFamily="sans-serif-medium"
            android:minWidth="88dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@drawable/cross_promo_button_bg"
            android:textAllCaps="false"
            android:stateListAnimator="@null" />

    </LinearLayout>

</LinearLayout>
